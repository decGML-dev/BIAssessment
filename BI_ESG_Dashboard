        // ==================== OPTIMIZED PDF GENERATION ====================
        function generateReportPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            
            const pageWidth = doc.internal.pageSize.width;
            const pageHeight = doc.internal.pageSize.height;
            const margin = 15; // Reduced margin for more space
            const contentWidth = pageWidth - (margin * 2);
            const rightMargin = pageWidth - margin;
            let y = 20;

            // Color palette
            const colors = {
                primary: [0, 120, 212],
                secondary: [115, 115, 115],
                accent: [16, 124, 16],
                warning: [255, 140, 0],
                danger: [209, 52, 56],
                lightBg: [240, 247, 255],
                white: [255, 255, 255]
            };

            // Helper Functions
            function addPageBorder() {
                doc.setDrawColor(...colors.primary);
                doc.setLineWidth(0.5);
                doc.rect(8, 8, pageWidth - 16, pageHeight - 16);
            }

            function addFooter(pageNum) {
                doc.setFontSize(8);
                doc.setTextColor(...colors.secondary);
                doc.setFont("helvetica", "italic");
                doc.text("Microsoft Corp | Q2 FY2026 ESG Brief", margin, pageHeight - 8);
                doc.text(`${pageNum}`, rightMargin, pageHeight - 8, { align: 'right' });
                doc.text("Student ID: 25189191", pageWidth / 2, pageHeight - 8, { align: 'center' });
                doc.setFont("helvetica", "normal");
            }

            function addSectionHeader(title, iconType = 'default') {
                checkPageBreak(30);
                
                // Colored bar
                doc.setFillColor(...colors.primary);
                doc.rect(margin, y, contentWidth, 10, 'F');
                
                // Icon
                drawIcon(margin + 2, y + 2, iconType);
                
                // Title text
                doc.setFontSize(14);
                doc.setTextColor(...colors.white);
                doc.setFont("helvetica", "bold");
                doc.text(title, margin + 12, y + 7);
                doc.setFont("helvetica", "normal");
                
                y += 14;
            }

            function drawIcon(x, y, type) {
                doc.setFillColor(...colors.white);
                switch(type) {
                    case 'summary':
                        doc.circle(x + 3, y + 3, 2.5, 'F');
                        doc.setFillColor(...colors.primary);
                        doc.circle(x + 3, y + 3, 1.5, 'F');
                        break;
                    case 'metrics':
                        doc.rect(x + 1, y + 1, 4, 4, 'F');
                        break;
                    case 'analysis':
                        doc.triangle(x + 3, y + 1, x + 1, y + 5, x + 5, y + 5, 'F');
                        break;
                    case 'recommendation':
                        doc.setLineWidth(1.5);
                        doc.setDrawColor(...colors.white);
                        doc.line(x + 1.5, y + 3, x + 2.5, y + 4.5);
                        doc.line(x + 2.5, y + 4.5, x + 5, y + 1.5);
                        break;
                    default:
                        doc.rect(x + 1.5, y + 1.5, 3, 3, 'F');
                }
            }

            function addSubHeader(text, color = colors.primary) {
                checkPageBreak(20);
                y += 2;
                
                // Accent line
                doc.setFillColor(...color);
                doc.rect(margin, y, 2, 6, 'F');
                
                doc.setFontSize(11);
                doc.setTextColor(...color);
                doc.setFont("helvetica", "bold");
                doc.text(text, margin + 5, y + 4.5);
                doc.setFont("helvetica", "normal");
                y += 9;
            }

            function addParagraph(text, indent = 0, size = 9) {
                checkPageBreak(25);
                doc.setFontSize(size);
                doc.setTextColor(40, 40, 40);
                const lines = doc.splitTextToSize(text, contentWidth - indent);
                doc.text(lines, margin + indent, y);
                y += (lines.length * 4.5) + 3;
            }

            function addCompactBullet(text) {
                checkPageBreak(15);
                doc.setFontSize(9);
                doc.setTextColor(40, 40, 40);
                
                // Bullet
                doc.setFillColor(...colors.primary);
                doc.circle(margin + 2, y - 0.5, 1, 'F');
                
                const lines = doc.splitTextToSize(text, contentWidth - 8);
                doc.text(lines, margin + 6, y);
                y += (lines.length * 4.5) + 2;
            }

            function addHighlightBox(text, bgColor = colors.lightBg, borderColor = colors.primary, compact = false) {
                checkPageBreak(30);
                
                const fontSize = compact ? 9 : 10;
                doc.setFontSize(fontSize);
                const lines = doc.splitTextToSize(text, contentWidth - 10);
                const boxHeight = (lines.length * (compact ? 4.5 : 5)) + (compact ? 8 : 10);
                
                // Background

    <style>
        :root {
            --ms-blue: #0078D4;
            --ms-dark: #242424;
            --ms-green: #107C10;
            --ms-red: #d13438;
            --ms-orange: #FF8C00;
            --ms-yellow: #FFB900;
            --ms-gray: #737373;
            --bg-color: #f8f9fa;
            --card-bg: #ffffff;
        }

        * { box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 20px; background-color: var(--bg-color); color: var(--ms-dark); }
        
        /* Layout & Header */
        header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 3px solid var(--ms-blue); padding-bottom: 15px; background: linear-gradient(135deg, #ffffff 0%, #f0f7ff 100%); padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .header-title h1 { margin: 0; font-size: 28px; color: var(--ms-blue); }
        .header-title h2 { margin: 5px 0 0; font-size: 16px; color: var(--ms-gray); font-weight: 400; }
        .student-id { font-weight: bold; color: var(--ms-blue); font-size: 14px; }

        /* Navigation Tabs */
        .tab-container { display: flex; gap: 5px; margin-bottom: 20px; border-bottom: 2px solid #e0e0e0; }
        .tab { padding: 12px 24px; background: transparent; border: none; cursor: pointer; font-weight: 600; color: var(--ms-gray); transition: all 0.3s; border-bottom: 3px solid transparent; }
        .tab:hover { background: #f0f7ff; }
        .tab.active { color: var(--ms-blue); border-bottom-color: var(--ms-blue); background: #f0f7ff; }

        .tab-content { display: none; }
        .tab-content.active { display: block; animation: fadeIn 0.3s; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* Action Buttons */
        .action-bar { display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }
        .btn { padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-weight: 600; transition: all 0.2s; }
        .btn-pdf { background-color: var(--ms-red); color: white; }
        .btn-ppt { background-color: #D24726; color: white; }
        .btn-export { background-color: var(--ms-green); color: white; }
        .btn:hover { opacity: 0.9; transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.2); }

        /* Snapshot */
        .snapshot-container { display: grid; grid-template-columns: 3fr 1fr; gap: 20px; margin-bottom: 25px; }
        .headline-card { background: linear-gradient(135deg, var(--ms-blue) 0%, #005a9e 100%); color: white; padding: 30px; border-radius: 8px; display: flex; flex-direction: column; justify-content: center; box-shadow: 0 4px 12px rgba(0,120,212,0.3); }
        .headline-card h3 { margin: 0 0 15px 0; opacity: 0.9; text-transform: uppercase; font-size: 14px; letter-spacing: 1px; }
        .headline-card p { margin: 0; font-size: 24px; font-weight: 600; line-height: 1.4; }
        
        .metrics-row { display: flex; flex-direction: column; gap: 15px; }
        .mini-metric { background: var(--card-bg); padding: 18px; border-radius: 8px; border-left: 5px solid var(--ms-gray); box-shadow: 0 2px 8px rgba(0,0,0,0.08); transition: transform 0.2s; }
        .mini-metric:hover { transform: translateX(5px); }
        .mini-metric.pos { border-left-color: var(--ms-green); }
        .mini-metric.neg { border-left-color: var(--ms-red); }
        .mini-metric .label { font-size: 13px; color: var(--ms-gray); text-transform: uppercase; }
        .mini-metric .value { font-size: 24px; font-weight: bold; margin: 4px 0; }
        .mini-metric .change { font-size: 13px; font-weight: 600; }

        /* Alert Banner */
        .alert-banner { background: linear-gradient(135deg, #fff4e6 0%, #ffe8cc 100%); border-left: 5px solid var(--ms-orange); padding: 20px; border-radius: 8px; margin-bottom: 25px; box-shadow: 0 2px 8px rgba(255,140,0,0.2); }
        .alert-banner h3 { margin: 0 0 10px 0; color: #d97700; font-size: 18px; display: flex; align-items: center; gap: 10px; }
        .alert-banner p { margin: 0; color: #5c3d00; line-height: 1.6; }

        /* KPI Grids */
        .section-header { font-size: 20px; font-weight: 600; margin: 30px 0 15px; padding-bottom: 8px; border-bottom: 2px solid #e0e0e0; display: flex; align-items: center; gap: 10px; }
        .dot { height: 14px; width: 14px; border-radius: 50%; display: inline-block; }
        
        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-bottom: 10px; }
        .kpi-card { background: var(--card-bg); padding: 22px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); position: relative; overflow: hidden; transition: all 0.3s; }
        .kpi-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.15); transform: translateY(-2px); }
        .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, var(--ms-blue), #00bcf2); }
        .kpi-card h4 { margin: 0 0 12px 0; font-size: 13px; color: var(--ms-gray); text-transform: uppercase; letter-spacing: 0.5px; }
        .kpi-card .val { font-size: 32px; font-weight: bold; color: var(--ms-dark); }
        .kpi-card .unit { font-size: 16px; font-weight: normal; color: var(--ms-gray); }
        .kpi-card .sub { font-size: 13px; margin-top: 10px; font-weight: 500; }
        .kpi-card .benchmark { font-size: 12px; margin-top: 8px; padding: 6px 10px; background: #f5f5f5; border-radius: 4px; display: inline-block; }
        .trend-up { color: var(--ms-red); }
        .trend-down { color: var(--ms-green); }
        .trend-pos { color: var(--ms-green); }

        /* Risk Matrix */
        .risk-matrix { background: white; padding: 25px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 25px; }
        .risk-grid { display: grid; grid-template-columns: 50px repeat(5, 1fr); grid-template-rows: repeat(5, 60px); gap: 2px; margin-top: 15px; }
        .risk-cell { border: 1px solid #ddd; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; }
        .risk-label { background: #f5f5f5; font-weight: bold; color: var(--ms-gray); }
        .risk-low { background: #e8f5e9; }
        .risk-medium { background: #fff9e6; }
        .risk-high { background: #ffebee; }
        .risk-critical { background: #d32f2f; color: white; }
        .risk-item { padding: 4px 8px; background: white; border: 2px solid; border-radius: 4px; font-size: 11px; text-align: center; }

        /* Competitive Benchmark */
        .benchmark-section { background: white; padding: 25px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 25px; }
        .benchmark-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-top: 15px; }
        .benchmark-card { padding: 15px; border: 2px solid #e0e0e0; border-radius: 6px; }
        .benchmark-card.leader { border-color: var(--ms-green); background: #f1f8f4; }
        .benchmark-card h4 { margin: 0 0 10px; font-size: 16px; }
        .benchmark-metric { display: flex; justify-content: space-between; margin: 8px 0; font-size: 13px; }

        /* Analysis & Charts Area */
        .analysis-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 25px; }
        .chart-card { background: var(--card-bg); padding: 25px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); height: 400px; }
        .chart-card.large { grid-column: 1 / -1; height: 450px; }
        
        .text-analysis { background: #fff; padding: 28px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-top: 5px solid var(--ms-red); }
        .text-analysis.positive { border-top-color: var(--ms-green); }
        .text-analysis.warning { border-top-color: var(--ms-orange); }
        .text-analysis h3 { margin-top: 0; color: var(--ms-dark); font-size: 20px; }
        .analysis-point { margin-bottom: 18px; padding-left: 20px; border-left: 3px solid #e0e0e0; }
        .analysis-point strong { color: var(--ms-blue); display: block; margin-bottom: 6px; font-size: 15px; }
        .analysis-point p { margin: 0; line-height: 1.6; color: #555; }

        /* Scenario Planning */
        .scenario-container { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 20px; }
        .scenario-card { padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .scenario-card.optimistic { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); border-top: 4px solid var(--ms-green); }
        .scenario-card.baseline { background: linear-gradient(135deg, #fff9e6 0%, #ffecb3 100%); border-top: 4px solid var(--ms-yellow); }
        .scenario-card.pessimistic { background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%); border-top: 4px solid var(--ms-red); }
        .scenario-card h4 { margin: 0 0 15px; font-size: 18px; }
        .scenario-metric { margin: 10px 0; font-size: 14px; }
        .scenario-metric strong { display: block; color: var(--ms-gray); font-size: 12px; text-transform: uppercase; margin-bottom: 4px; }

        /* Materiality Matrix */
        .materiality-container { background: white; padding: 25px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 25px; }
        .materiality-canvas { width: 100%; height: 400px; border: 1px solid #e0e0e0; background: linear-gradient(to top, #f5f5f5 0%, white 100%); position: relative; }
        
        /* Timeline */
        .timeline { position: relative; padding: 20px 0; }
        .timeline-item { display: flex; gap: 20px; margin-bottom: 30px; position: relative; }
        .timeline-item::before { content: ''; position: absolute; left: 19px; top: 30px; bottom: -30px; width: 2px; background: #e0e0e0; }
        .timeline-item:last-child::before { display: none; }
        .timeline-dot { width: 40px; height: 40px; border-radius: 50%; background: var(--ms-blue); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold; flex-shrink: 0; z-index: 1; }
        .timeline-content { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); flex: 1; }
        .timeline-content h4 { margin: 0 0 10px; color: var(--ms-blue); }

        /* Stakeholder Impact */
        .stakeholder-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 20px; }
        .stakeholder-card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); border-left: 5px solid var(--ms-blue); }
        .stakeholder-card h4 { margin: 0 0 15px; display: flex; align-items: center; gap: 10px; font-size: 16px; }
        .impact-item { margin: 8px 0; padding: 8px; background: #f9f9f9; border-radius: 4px; font-size: 13px; }
        .impact-positive { border-left: 3px solid var(--ms-green); }
        .impact-negative { border-left: 3px solid var(--ms-red); }

        @media (max-width: 1200px) {
            .snapshot-container, .analysis-grid { grid-template-columns: 1fr; }
            .scenario-container { grid-template-columns: 1fr; }
        }

        @media (max-width: 768px) {
            .metrics-row { flex-direction: column; }
            .kpi-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
